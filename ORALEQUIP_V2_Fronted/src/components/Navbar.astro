---
import { NavbarMobile } from './NavbarMobile';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/blog', label: 'Blog & Insights' },
  { href: '/about', label: 'About Us' },
];
---

<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-[var(--border)] relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div class="w-9 h-9 bg-[var(--primary)] rounded-xl flex items-center justify-center text-xl">
          🦷
        </div>
        <span class="text-[var(--foreground)] text-xl font-bold">
          oral<span class="text-[var(--primary)]">equip</span>
        </span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-xl transition-colors text-sm font-medium ${
              currentPath === link.href
                ? 'bg-[var(--primary)]/10 text-[var(--primary)]'
                : 'text-[var(--muted-foreground)] hover:text-[var(--foreground)] hover:bg-[var(--muted)]'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex">
        <a
          href="mailto:info@oralequip.com"
          class="bg-[var(--primary)] text-white px-5 py-2.5 rounded-xl hover:opacity-90 transition-opacity text-sm font-semibold"
        >
          Request a Quote
        </a>
      </div>

      <!-- Mobile Menu (React island) -->
      <NavbarMobile currentPath={currentPath} client:load />
    </div>
  </div>
</nav>
