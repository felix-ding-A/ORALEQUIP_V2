---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { ProductFilter } from '../../components/ProductFilter';
import { sanityClient } from '../../utils/sanity';

const products = await sanityClient.fetch(`*[_type == "product"] | order(_createdAt desc) {
  _id,
  title,
  slug,
  category,
  material,
  image { "url": asset->url, alt },
  gallery[] { "url": asset->url, alt },
  description,
  specs,
  clinicalApplications,
  features
}`);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.oralequip.com/' },
    { '@type': 'ListItem', position: 2, name: 'Premium Selection', item: 'https://www.oralequip.com/premium-selection' },
  ],
};
---

<BaseLayout
  title="Advanced Compact Dental Equipment & Clinical Devices | ORALEQUIP"
  description="Explore our comprehensive range of compact dental equipment designed to optimize clinical workflow. We provide reliable, space-saving solutions for efficient endodontic and restorative treatments."
  jsonLd={breadcrumbJsonLd}
>
  <Navbar />

  <main class="min-h-screen" style="background: var(--background);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <!-- Breadcrumb -->
      <Breadcrumbs items={[{ label: 'Premium Selection' }]} className="mb-6" />

      <div class="flex items-center justify-between mb-8">
        <h1 class="font-bold" style="color: var(--foreground); font-size: clamp(24px, 3vw, 36px);">
          Premium Selection & Clinical Solutions
        </h1>
      </div>

      <!-- ProductFilter is a React island — handles filtering & grid interactively -->
      <ProductFilter products={products} client:load />
    </div>
  </main>

  <Footer />
</BaseLayout>
