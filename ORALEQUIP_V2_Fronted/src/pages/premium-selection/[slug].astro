---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { ProductDetail } from '../../components/ProductDetail';
import { sanityClient } from '../../utils/sanity';

export async function getStaticPaths() {
  const query = `*[_type == "product"] {
    _id,
    title,
    slug,
    category,
    material,
    image { "url": asset->url, alt },
    gallery[] { "url": asset->url, alt },
    description,
    specs,
    clinicalApplications,
    features,
    faqs[] {
      question,
      answer
    }
  }`;

  const products = await sanityClient.fetch(query);
  return products.map((product: any) => ({
    params: { slug: product.slug.current },
    props: { product, allProducts: products },
  }));
}

const { product, allProducts } = Astro.props;
const related = allProducts.filter((p: any) => p._id !== product._id).slice(0, 4);

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description[0]?.children[0]?.text ?? '',
  brand: { '@type': 'Brand', name: 'OralEquip — ORALEQUIP' },
  image: product.image.url,
  category: product.category,
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    seller: { '@type': 'Organization', name: 'OralEquip' },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127',
  },
};

const displayFaqs = product.faqs?.length ? product.faqs : [
  {
    question: `Is the ${product.title} clinic-tested?`,
    answer: `Yes, all products at OralEquip, including the ${product.title}, are rigorously tested and approved by practicing doctors at ORALEQUIP clinic for professional use.`,
  },
  {
    question: 'Do you offer bulk B2B pricing?',
    answer: 'Yes, OralEquip specializes in B2B supply. You can add items to your inquiry cart and request a customized quote for volume orders.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: displayFaqs.map((f: any) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.oralequip.com/' },
    { '@type': 'ListItem', position: 2, name: 'Premium Selection', item: 'https://www.oralequip.com/premium-selection' },
    { '@type': 'ListItem', position: 3, name: product.title, item: `https://www.oralequip.com/premium-selection/${product.slug.current}` },
  ],
};
---

<BaseLayout
  title={`${product.title} | Dental ${product.category} | OralEquip`}
  description={`${product.title} — clinic-tested ${product.category.toLowerCase()} approved by ORALEQUIP. Request a B2B quote from OralEquip today.`}
  ogImage={product.image.url}
  jsonLd={[productJsonLd, breadcrumbJsonLd, faqJsonLd]}
>
  <Navbar />

  <main class="min-h-screen" style="background: var(--background);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <!-- Breadcrumb (static for SEO) -->
      <Breadcrumbs
        items={[
          { label: 'Premium Selection', href: '/premium-selection' },
          { label: product.title }
        ]}
        className="mb-8"
      />

      <!-- ProductDetail is a React island for gallery & tab interactivity -->
      <ProductDetail product={product} related={related} client:load />
    </div>
  </main>

  <Footer />
</BaseLayout>
