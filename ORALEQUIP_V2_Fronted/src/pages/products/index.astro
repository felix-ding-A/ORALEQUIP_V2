---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { ProductFilter } from '../../components/ProductFilter';
import { products } from '../../data/products';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://oralequip.com/' },
    { '@type': 'ListItem', position: 2, name: 'Products', item: 'https://oralequip.com/products' },
  ],
};
---

<BaseLayout
  title="Dental Products Catalog | Instruments, Equipment & Consumables | OralEquip"
  description="Browse OralEquip's B2B dental product catalog — clinic-tested instruments, equipment, and consumables handpicked by HI SMILE DENTAL doctors. Request quotes instantly."
  jsonLd={breadcrumbJsonLd}
>
  <Navbar />

  <main class="min-h-screen" style="background: var(--background);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1 text-sm mb-6" style="color: var(--muted-foreground);" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--primary)] transition-colors">Home</a>
        <span>›</span>
        <span style="color: var(--foreground);">Products</span>
      </nav>

      <div class="flex items-center justify-between mb-8">
        <h1 class="font-bold" style="color: var(--foreground); font-size: clamp(24px, 3vw, 36px);">
          Our Product Catalog
        </h1>
      </div>

      <!-- ProductFilter is a React island — handles filtering & grid interactively -->
      <ProductFilter products={products} client:load />
    </div>
  </main>

  <Footer />
</BaseLayout>
