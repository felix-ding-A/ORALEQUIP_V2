---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { sanityClient } from '../../utils/sanity';

// Fetch live blog posts from Sanity Backend
const blogPosts = await sanityClient.fetch(`*[_type == "post"] | order(_createdAt desc) {
  title,
  slug,
  excerpt,
  author,
  clinic,
  date,
  readTime,
  featured,
  image {
    "url": asset->url,
    alt
  }
}`);

const featured = blogPosts.find((p: any) => p.featured);
const rest = blogPosts.filter((p: any) => !p.featured);

const trendingTopics = [
  'Digital Impressions', '3D Printing', 'AI in Dentistry',
  'Bioactive Materials', 'Minimally Invasive', 'Patient Communication',
];

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://oralequip.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog & Insights', item: 'https://oralequip.com/blog' },
  ],
};
---

<BaseLayout
  title="Dental Industry Blog & Clinical Purchasing Insights | ORALEQUIP"
  description="Stay informed with the latest dental industry trends, clinical workflow tips, and expert purchasing guides for professional consumables and compact clinic devices."
  jsonLd={breadcrumbJsonLd}
>
  <Navbar />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 -mb-4 relative z-10">
    <Breadcrumbs items={[{ label: 'Blog & Insights' }]} />
  </div>

  <main class="min-h-screen" style="background: var(--background);">

    <!-- Page Header -->
    <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 mt-4 text-center">
      <h1 class="font-bold text-[var(--foreground)]" style="font-size: clamp(28px, 4vw, 48px); line-height: 1.2;">
        Dental Industry Insights & Expert Resources
      </h1>
      <p class="mt-4 text-lg text-[var(--muted-foreground)] max-w-3xl mx-auto">
        Stay informed with the latest dental industry trends, clinical workflow tips, and expert purchasing guides.
      </p>
    </header>

    <!-- Featured Article Hero -->
    {featured && (
      <section style="background: linear-gradient(135deg, var(--secondary) 0%, var(--background) 50%, #E8F5E9 100%);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
          <div class="grid md:grid-cols-2 gap-10 items-center">
            <div>
              <span
                class="inline-block px-3 py-1 rounded-full mb-4 text-sm font-semibold"
                style="background: var(--accent); color: var(--accent-foreground);"
              >
                ⭐ Featured Article
              </span>
              <h2
                class="font-bold mb-4"
                style="color: var(--foreground); font-size: clamp(24px, 3.5vw, 40px); line-height: 1.2;"
              >
                {featured.title}
              </h2>
              <p class="mb-6" style="color: var(--muted-foreground); font-size: 18px; line-height: 1.7;">
                {featured.excerpt}
              </p>
              <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--muted-foreground);">
                <span>👤 {featured.author} — {featured.clinic}</span>
                <span>⏱ {featured.readTime}</span>
                <span>📅 {featured.date}</span>
              </div>
              <a
                href={`/blog/${featured.slug.current}`}
                class="inline-flex items-center gap-2 text-white px-6 py-3 rounded-xl hover:opacity-90 transition-opacity font-semibold mt-6"
                style="background: var(--primary);"
              >
                Read Article →
              </a>
            </div>
            <div class="rounded-2xl overflow-hidden shadow-xl border-4 border-white">
              <img
                src={featured.image.url}
                alt={featured.image.alt ?? featured.title}
                class="w-full object-cover"
                style="height: 300px;"
                loading="eager"
                fetchpriority="high"
                width="600"
                height="300"
              />
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Articles Grid + Sidebar -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- Articles Grid -->
        <div class="flex-1">
          <h2 class="font-bold mb-6" style="color: var(--foreground); font-size: clamp(20px, 2.5vw, 28px);">
            Latest Articles
          </h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {rest.map((article) => (
              <article class="group bg-white rounded-2xl overflow-hidden border hover:shadow-lg transition-all hover:-translate-y-1" style="border-color: var(--border);">
                <div class="overflow-hidden" style="aspect-ratio: 16/10;">
                  <img
                    src={article.image.url}
                    alt={article.image.alt ?? article.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="400"
                    height="250"
                  />
                </div>
                <div class="p-5">
                  <h2 class="font-semibold mb-2 group-hover:transition-colors" style="color: var(--foreground); font-size: 17px; line-height: 1.4;">
                    <a href={`/blog/${article.slug.current}`} class="hover:text-[var(--primary)] transition-colors">
                      {article.title}
                    </a>
                  </h2>
                  <p class="mb-4 text-sm" style="color: var(--muted-foreground); line-height: 1.6;">
                    {article.excerpt}
                  </p>
                  <div class="flex flex-wrap items-center gap-3 text-xs" style="color: var(--muted-foreground);">
                    <span>👤 {article.author}</span>
                    <span>📅 {article.date}</span>
                    <span>⏱ {article.readTime}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="w-full lg:w-72 shrink-0 space-y-6">
          <!-- Trending Topics -->
          <div class="bg-white rounded-2xl border p-6" style="border-color: var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-[var(--primary)]">📈</span>
              <h3 class="font-semibold" style="color: var(--foreground);">Trending Topics</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {trendingTopics.map((topic) => (
                <span
                  class="px-3 py-1.5 rounded-full text-sm cursor-pointer hover:opacity-80 transition-opacity"
                  style="background: rgba(77,182,172,0.1); color: var(--primary);"
                >
                  {topic}
                </span>
              ))}
            </div>
          </div>

          <!-- Newsletter -->
          <div
            class="rounded-2xl p-6"
            style="background: linear-gradient(135deg, rgba(77,182,172,0.1), rgba(255,224,130,0.2));"
          >
            <div class="text-center mb-4">
              <span class="text-5xl">
                <img src="/pageicon.svg" alt="OralEquip Icon" class="w-[1.25em] h-[1.25em] mx-auto inline-block object-contain" />
              </span>
              <h3 class="font-semibold mt-2" style="color: var(--foreground);">Subscribe to Our Newsletter</h3>
              <p class="mt-1 text-sm" style="color: var(--muted-foreground);">
                Get the latest dental insights delivered weekly!
              </p>
            </div>
            <form class="space-y-3" method="POST" action="/api/subscribe">
              <input
                type="email"
                name="email"
                placeholder="Your email address"
                required
                class="w-full bg-white border rounded-xl px-4 py-2.5 text-sm focus:outline-none"
                style="border-color: var(--border); color: var(--foreground);"
              />
              <button
                type="submit"
                class="w-full flex items-center justify-center gap-2 text-white px-4 py-2.5 rounded-xl hover:opacity-90 transition-opacity font-semibold text-sm"
                style="background: var(--primary);"
              >
                ✉️ Subscribe
              </button>
            </form>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
