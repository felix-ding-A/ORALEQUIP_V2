---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'OralEquip — ORALEQUIP',
    url: Astro.site?.href,
    logo: new URL('/favicon.svg', Astro.site).href,
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'info@oralequip.com',
      contactType: 'customer support',
    },
    sameAs: [
      'https://www.facebook.com/oralequip',
      'https://www.linkedin.com/company/oralequip',
      'https://www.instagram.com/oralequip',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'OralEquip',
    url: Astro.site?.href,
    description: 'B2B dental supplies recommended by ORALEQUIP doctors. Premium instruments, equipment, and consumables.',
  },
];

const categories = [
  {
    title: 'Instruments',
    desc: 'Precision tools for every procedure',
    icon: '🔬',
    color: '#EFF6FF',
    iconBg: '#DBEAFE',
  },
  {
    title: 'Equipment',
    desc: 'Advanced dental technology',
    icon: '⚙️',
    color: '#F0FDF4',
    iconBg: '#DCFCE7',
  },
  {
    title: 'Consumables',
    desc: 'Quality materials that last',
    icon: '📦',
    color: '#FFF0F6',
    iconBg: '#FCE7F3',
  },
];

const trustPillars = [
  { icon: '🏆', label: 'Clinic-Tested', desc: 'Every product approved by our doctors' },
  { icon: '🛡️', label: 'Quality Assured', desc: 'Rigorous material testing standards' },
  { icon: '❤️', label: 'Patient-First', desc: 'Designed for better outcomes' },
];
---

<BaseLayout
  title="Premium Dental Consumables & Compact Equipment Supplier | ORALEQUIP"
  description="Discover high-quality dental consumables, precision hand instruments, and compact clinical equipment for modern practices. Reliable B2B solutions and global shipping."
  jsonLd={jsonLd}
>
  <Navbar />

  <main>
    <!-- ═══ HERO SECTION Redesign ═══ -->
    <section class="relative min-h-[600px] flex items-center overflow-hidden bg-slate-900">
      <!-- Full-Width Background Image -->
      <div class="absolute inset-0 z-0">
        <img
          src="/image/Dr song's dental clinic.webp"
          alt="Dr song's dental clinic - Professional ORALEQUIP medical staff smiling"
          class="w-full h-full object-cover opacity-80"
          loading="eager"
          fetchpriority="high"
          width="1920"
          height="1080"
        />
        <!-- Sophisticated Gradient Overlay for readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
      </div>

      <!-- Hero Content -->
      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
        <div class="max-w-2xl transform transition-all duration-700 ease-out translate-y-0 opacity-100">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-bold bg-white/10 backdrop-blur-md text-white border border-white/20 shadow-xl">
            <span class="flex h-2 w-2 rounded-full bg-[#4DB6AC] animate-pulse"></span>
            🛡️ Trusted by 500+ dental clinics
          </div>
          <h1 class="text-white mb-6 font-extrabold leading-[1.1] drop-shadow-2xl" style="font-size: clamp(36px, 5vw, 64px);">
            High-Quality Dental <span class="text-[#4DB6AC]">Consumables</span> & Compact Equipment
          </h1>
          <p class="text-white/90 mb-10 text-lg md:text-xl leading-relaxed max-w-xl font-medium drop-shadow-lg">
            Discover clinic-tested dental instruments, equipment, and consumables — handpicked by practicing dentists for outstanding patient outcomes.
          </p>
          <div class="flex flex-wrap gap-5">
            <a
              href="/premium-selection"
              class="group relative inline-flex items-center gap-3 bg-[#4DB6AC] text-white px-8 py-4 rounded-2xl font-bold transition-all hover:scale-105 active:scale-95 shadow-2xl shadow-[#4DB6AC]/40"
            >
              Explore Products
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="/about"
              class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-xl border border-white/20 text-white px-8 py-4 rounded-2xl font-bold hover:bg-white/20 transition-all shadow-xl"
            >
              Our Story
            </a>
          </div>
        </div>
      </div>

      <!-- Premium Floating Badge -->
      <div class="absolute bottom-10 right-8 md:right-12 z-10 hidden sm:flex items-center gap-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-5 shadow-2xl animate-bounce-subtle">
        <div class="w-14 h-14 rounded-2xl bg-[#FFE082] flex items-center justify-center text-3xl shadow-inner">
          ⭐
        </div>
        <div>
          <p class="text-white font-black text-lg leading-tight">4.9/5 Rating</p>
          <p class="text-white/60 text-xs font-bold uppercase tracking-widest">Global Trusted</p>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-50 hover:opacity-100 transition-opacity cursor-pointer">
        <span class="text-white/60 text-[10px] font-bold uppercase tracking-tighter">Scroll</span>
        <div class="w-[1px] h-12 bg-gradient-to-b from-white to-transparent"></div>
      </div>
    </section>

    <!-- ═══ TRUST / ORALEQUIP SECTION ═══ -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-6" style="background: rgba(255,224,130,0.35);">
          <img src="/pageicon.svg" alt="OralEquip Icon" class="w-12 h-12 object-contain" />
        </div>
        <h2 class="text-[var(--foreground)] mb-4 font-bold" style="font-size: clamp(22px, 3vw, 32px);">
          Created by <span class="text-[var(--primary)]">ORALEQUIP</span>
        </h2>
        <p class="text-[var(--muted-foreground)] max-w-2xl mx-auto" style="font-size: 18px; line-height: 1.7;">
          We started as a dental clinic. Our doctors tested hundreds of products and selected only the best.
          Now, we share these carefully vetted materials with dentists worldwide — because every patient deserves
          the highest quality care.
        </p>
        <div class="flex flex-wrap justify-center gap-8 mt-10">
          {trustPillars.map((item) => (
            <div class="flex flex-col items-center gap-2" style="width: 180px;">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background: rgba(77,182,172,0.1);">
                {item.icon}
              </div>
              <p class="text-[var(--foreground)] font-semibold text-sm">{item.label}</p>
              <p class="text-[var(--muted-foreground)] text-sm text-center">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CATEGORY GRID ═══ -->
    <section class="py-16 md:py-20" style="background: var(--background);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-[var(--foreground)] mb-3 font-bold" style="font-size: clamp(22px, 3vw, 32px);">
            Browse Our Categories
          </h2>
          <p class="text-[var(--muted-foreground)]">Find exactly what your practice needs</p>
        </div>
        <div class="grid sm:grid-cols-3 gap-6">
          {categories.map((cat) => (
            <a
              href="/products"
              class="group rounded-2xl p-8 text-center hover:shadow-lg transition-all hover:-translate-y-1 border border-transparent hover:border-[var(--border)]"
              style={`background: ${cat.color};`}
            >
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl group-hover:scale-110 transition-transform" style={`background: ${cat.iconBg};`}>
                {cat.icon}
              </div>
              <h3 class="text-[var(--foreground)] mb-2 font-semibold">{cat.title}</h3>
              <p class="text-[var(--muted-foreground)] text-sm">{cat.desc}</p>
              <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium" style="color: var(--primary);">
                Explore →
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ SEO CONTENT AREA ═══ -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-[var(--foreground)] mb-6 font-bold" style="font-size: clamp(20px, 2.5vw, 28px);">
          Why Dental Professionals Choose OralEquip
        </h2>
        <div class="space-y-4 text-[var(--muted-foreground)]" style="line-height: 1.8;">
          <p>
            In the rapidly evolving world of dental care, having access to reliable, high-quality supplies is paramount.
            OralEquip was born from the real-world experience of <strong class="text-[var(--foreground)]">ORALEQUIP</strong> — a clinic that understands the
            challenges dentists face daily. Our curated selection spans precision instruments, state-of-the-art
            equipment, and essential consumables, all rigorously tested in clinical settings.
          </p>
          <p>
            Whether you're outfitting a new practice or upgrading your existing toolkit, our B2B platform makes it easy
            to request quotes on bulk orders. We work directly with manufacturers to ensure competitive pricing without
            compromising the quality standards that dental professionals expect. Every product in our catalog has
            been vetted and approved by practicing dentists at ORALEQUIP.
          </p>
          <p>
            From composite resins and bonding agents to digital imaging equipment and ergonomic hand instruments, we
            cover the full spectrum of dental supply needs. Join hundreds of clinics worldwide that trust OralEquip for
            their procurement needs. Request a quote today and experience the difference that clinic-tested supplies
            can make in your practice.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
