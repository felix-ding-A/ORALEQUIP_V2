---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const timeline = [
  { year: '2015', title: 'ORALEQUIP Opens', desc: 'Our founding doctors opened a small but ambitious dental clinic in Los Angeles, focused on delivering exceptional patient care.' },
  { year: '2018', title: 'Material Testing Begins', desc: 'Frustrated with inconsistent supply quality, our doctors began systematically testing and documenting every material used in the clinic.' },
  { year: '2021', title: 'OralEquip is Born', desc: 'With a curated list of 200+ clinic-approved products, we launched OralEquip to share our findings with dental professionals worldwide.' },
  { year: '2026', title: 'Global Reach', desc: 'Today, over 500 clinics across 30 countries trust OralEquip for their dental supply needs, all backed by our doctors\' seal of approval.' },
];

const standards = [
  { icon: '🛡️', title: 'Clinical Testing', desc: 'Every product is used in real clinical settings for a minimum of 6 months before listing.' },
  { icon: '🎯', title: 'Performance Metrics', desc: 'We track durability, patient comfort, and ease of use across hundreds of procedures.' },
  { icon: '❤️', title: 'Patient Safety First', desc: 'Biocompatibility and safety certifications are non-negotiable requirements for all products.' },
  { icon: '✨', title: 'Continuous Review', desc: 'Products are re-evaluated annually. If better options emerge, we update our catalog.' },
];

const aboutJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About OralEquip — ORALEQUIP',
  description: 'OralEquip was created by ORALEQUIP to share clinic-tested dental supplies with professionals worldwide.',
  url: 'https://oralequip.com/about',
};
---

<BaseLayout
  title="About OralEquip | ORALEQUIP — Our Story & Mission"
  description="OralEquip was born from ORALEQUIP, a dental clinic that tests and recommends only the best dental supplies to professionals worldwide. Learn our story."
  jsonLd={aboutJsonLd}
>
  <Navbar />

  <main class="min-h-screen" style="background: var(--background);">

    <!-- ═══ HERO ═══ -->
    <section class="relative overflow-hidden" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--background) 50%, #E8F5E9 100%);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div
              class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 text-sm"
              style="background: rgba(255,224,130,0.5); color: var(--foreground);"
            >
              <img src="/pageicon.svg" alt="Our Story Icon" class="w-6 h-6 object-contain" /> Our Story
            </div>
            <h1
              class="font-bold mb-6"
              style="color: var(--foreground); font-size: clamp(28px, 4vw, 44px); line-height: 1.2;"
            >
              From a Dental Clinic to a{' '}
              <span class="text-[var(--primary)]">Global Supply Partner</span>
            </h1>
            <p style="color: var(--muted-foreground); font-size: 18px; line-height: 1.7;">
              ORALEQUIP began as a simple idea: what if a dental clinic curated and shared the very best materials
              with colleagues everywhere? That's exactly what we did — and OralEquip was born.
            </p>
          </div>
          <div class="relative">
            <div class="rounded-3xl overflow-hidden border-4 border-white" style="box-shadow: 0 25px 50px rgba(77,182,172,0.15);">
              <img
                src="https://images.unsplash.com/photo-1642844819197-5f5f21b89ff8?w=800&q=80"
                alt="ORALEQUIP clinic interior"
                class="w-full object-cover"
                style="height: 350px;"
                loading="eager"
                fetchpriority="high"
                width="800"
                height="350"
              />
            </div>
            <!-- Floating badge -->
            <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-lg px-5 py-3 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg" style="background: rgba(77,182,172,0.1); color: var(--primary);">
                👥
              </div>
              <div>
                <p class="font-bold text-sm" style="color: var(--foreground);">500+ Clinics</p>
                <p class="text-xs" style="color: var(--muted-foreground);">Trust our selection</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ TIMELINE ═══ -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-bold mb-3" style="color: var(--foreground); font-size: clamp(22px, 3vw, 32px);">
            The ORALEQUIP Story
          </h2>
          <p style="color: var(--muted-foreground); font-size: 18px;">
            Why a dental clinic started a B2B supply company
          </p>
        </div>

        <div class="relative">
          <!-- Timeline vertical line -->
          <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-0.5 -translate-x-1/2" style="background: rgba(77,182,172,0.2);"></div>

          <div class="space-y-12">
            {timeline.map((item, i) => (
              <div class={`relative flex flex-col md:flex-row gap-6 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
                <!-- Timeline dot -->
                <div
                  class="absolute left-6 md:left-1/2 w-4 h-4 rounded-full -translate-x-1/2 mt-1.5 z-10 ring-4 ring-white"
                  style="background: var(--primary);"
                ></div>

                <div class={`md:w-1/2 pl-14 md:pl-0 ${i % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
                  <span
                    class="inline-block px-3 py-1 rounded-full mb-2 text-sm font-bold text-white"
                    style="background: var(--primary);"
                  >
                    {item.year}
                  </span>
                  <h3 class="font-semibold mb-2" style="color: var(--foreground);">{item.title}</h3>
                  <p style="color: var(--muted-foreground); line-height: 1.7;">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ OUR DOCTORS' STANDARDS ═══ -->
    <section class="py-16 md:py-20" style="background: var(--background);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="font-bold mb-4" style="color: var(--foreground); font-size: clamp(22px, 3vw, 32px);">
              Our Doctors' Standards
            </h2>
            <p class="mb-8" style="color: var(--muted-foreground); font-size: 18px; line-height: 1.7;">
              At ORALEQUIP, we don't just sell products — we use them first. Our rigorous evaluation process
              ensures that only the best materials make it to our catalog.
            </p>
            <div class="grid sm:grid-cols-2 gap-6">
              {standards.map((item) => (
                <div class="bg-white rounded-2xl p-5 border" style="border-color: var(--border);">
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3 text-xl" style="background: rgba(77,182,172,0.1);">
                    {item.icon}
                  </div>
                  <h4 class="font-semibold mb-1" style="color: var(--foreground);">{item.title}</h4>
                  <p class="text-sm" style="color: var(--muted-foreground); line-height: 1.6;">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
          <!-- Team images -->
          <div class="space-y-4">
            <div class="rounded-2xl overflow-hidden border-4 border-white shadow-xl">
              <img
                src="https://images.unsplash.com/photo-1758205308181-d52b41e00cef?w=800&q=80"
                alt="ORALEQUIP team of dental professionals"
                class="w-full object-cover"
                style="height: 230px;"
                loading="lazy"
                width="600"
                height="230"
              />
            </div>
            <div class="rounded-2xl overflow-hidden border-4 border-white shadow-xl">
              <img
                src="https://images.unsplash.com/photo-1675526607070-f5cbd71dde92?w=800&q=80"
                alt="Friendly dentist at ORALEQUIP testing materials"
                class="w-full object-cover"
                style="height: 230px;"
                loading="lazy"
                width="600"
                height="230"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <div class="rounded-3xl p-10 md:p-14" style="background: linear-gradient(135deg, rgba(77,182,172,0.1), rgba(255,224,130,0.2));">
          <span class="text-5xl">🤝</span>
          <h2 class="font-bold mt-4 mb-3" style="color: var(--foreground); font-size: clamp(22px, 3vw, 32px);">
            Ready to Partner With Us?
          </h2>
          <p class="mb-8" style="color: var(--muted-foreground); font-size: 18px;">
            Join 500+ dental clinics that trust OralEquip for their professional supply needs. Request a quote today.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="mailto:info@oralequip.com"
              class="inline-flex items-center gap-2 text-white px-8 py-3.5 rounded-xl hover:opacity-90 transition-opacity font-semibold"
              style="background: var(--primary);"
            >
              🏆 Request a Quote
            </a>
            <a
              href="/products"
              class="inline-flex items-center gap-2 bg-white text-[var(--foreground)] px-8 py-3.5 rounded-xl border hover:bg-[var(--muted)] transition-colors font-medium"
            >
              Browse Products →
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
